    "4b50b650-2c37-4d0c-9812-ca92dd4f0320": {
      "id": "4b50b650-2c37-4d0c-9812-ca92dd4f0320",
      "name": "Background task monitoring & sub-agents",
      "description": "Add support for long-running/background process monitoring in the heartbeat task system. Key requirements: (1) Spawn background processes and track them (pid, log file, associated task), (2) Persistent sub-agent context that accumulates state across ticks (not one-shot), (3) New task type like @watch/@monitor that re-runs each tick with accumulated context, (4) Task LLM gets tool access to write back to HEARTBEAT.md for scheduling follow-ups.",
      "acceptanceCriteria": "Can spawn a background process from a task, monitor it across ticks with accumulated LLM context, and have the task agent schedule follow-up checks",
      "columnId": "4",
      "sessionName": "nemoclaw",
      "dir": "/Users/jordan/devel/personal/nemoclaw",
      "command": "claude",
      "worktree": false,
      "createdAt": 1773724017617,
      "closedAt": 1773727433906
    },
