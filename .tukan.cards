    "39c9bde4-4242-4e29-9245-27fd148b96de": {
      "id": "39c9bde4-4242-4e29-9245-27fd148b96de",
      "columnId": "4",
      "name": "slash commmands",
      "description": "Let's implement slash commands to make it easier to debug and check custom behavior. Commands should be /something and will run a determined prompt or action. Something like /reset would be a deterministic action and would erase the current context. Something like /context would be a hybrid - first it will see what and how long the context is and then send that to the model to show the stats as well as a synopsis of what is in the context. The final type will be pure model where it would basically be a manually invoked skill.",
      "acceptanceCriteria": "",
      "sessionName": "talon",
      "dir": "/home/jordan/devel/personal/talon",
      "command": "shell",
      "worktree": false,
      "createdAt": 1774749842694,
      "startedAt": 1774749845714,
      "closedAt": 1774754390470
    },
